{
  "name": "kodo",
  "version": "1.0.0",
  "description": "Kodo Manga Reader",
  "scripts": {
    "dev": "npx @tauri-apps/cli dev",
    "build": "npx @tauri-apps/cli build",
    "tauri:build": "npx @tauri-apps/cli build",
    "dev:quick": "cd client && npm run build && cd ../src-tauri && cargo build && cd .. && .\\src-tauri\\target\\debug\\kodo.exe",
    "dev:server": "cd server && node index.js",
    "build:client": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.6",
    "googleapis": "^171.4.0",
    "multer": "^2.0.2",
    "sharp": "^0.34.5",
    "svg2img": "^1.0.0-beta.2",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0"
  }
}
