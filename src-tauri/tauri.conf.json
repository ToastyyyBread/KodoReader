{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kōdo",
  "version": "1.1.2",
  "identifier": "com.kodo.app",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://127.0.0.1:19999",
    "beforeDevCommand": "cd client && npm run dev -- --host 127.0.0.1 --port 19999",
    "beforeBuildCommand": "cd client && npm run build && cd .. && scripts\\copy-node-runtime.cmd"
  },
  "app": {
    "windows": [
      {
        "title": "Kōdo",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "visible": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "bin/node.exe",
      "../config.json",
      "../server",
      "../client/dist",
      "../upscaler"
    ],
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/installer.ico"
      }
    }
  }
}